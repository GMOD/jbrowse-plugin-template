{
  "version": "0.0.1",
  "license": "MIT",
  "name": "jbrowse-plugin-template",
  "keywords": [
    "jbrowse",
    "jbrowse2"
  ],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "format": "pnpm prettier --write .",
    "prebuild": "pnpm clean",
    "start": "NODE_ENV=development rollup -c rollup.config.mjs --watch",
    "serve": "serve --cors --listen 9000 .",
    "build": "tsc && NODE_ENV=production rollup -c rollup.config.mjs",
    "build:bundle": "NODE_ENV=production rollup -c rollup.config.mjs",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "pretest:e2e": "test -d .test-jbrowse-nightly || jbrowse create .test-jbrowse-nightly --nightly",
    "prepack": "pnpm build",
    "preversion": "pnpm lint",
    "version": "node -e \"console.log('export const version = \\'' + require('./package.json').version + '\\'')\" > src/version.ts && git add src/version.ts",
    "postversion": "git push --follow-tags"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@eslint/js": "^10.0.1",
    "@jbrowse/cli": "^4.2.1",
    "@jbrowse/core": "^4.2.0",
    "@jbrowse/mobx-state-tree": "^5.6.0",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "^7.3.10",
    "@mui/system": "^7.3.10",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^26.1.0",
    "mobx": "^6.15.0",
    "mobx-react": "^9.2.1",
    "prettier": "^3.8.3",
    "puppeteer": "^24.42.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rimraf": "^6.1.3",
    "rollup": "^4.34.9",
    "rollup-plugin-external-globals": "^0.13.0",
    "serve": "^14.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "puppeteer",
      "unrs-resolver"
    ]
  }
}
